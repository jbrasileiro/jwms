<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.jbrasileiro.jwms.MainViewController">
  <top>
    <MenuBar>
      <Menu mnemonicParsing="false" text="Ficheiro">
        <MenuItem mnemonicParsing="false" onAction="#onOpenProject" text="Abrir…" />
      </Menu>
    </MenuBar>
  </top>
  <center>
    <SplitPane dividerPositions="0.55" fx:id="mainSplit">
      <VBox spacing="8.0">
        <padding>
          <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
        </padding>
        <Label text="Entradas (relativas):" />
        <ListView fx:id="entryList" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
      </VBox>
      <VBox spacing="8.0">
        <padding>
          <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
        </padding>
        <Button mnemonicParsing="false" onAction="#onOpenProject" text="Abrir projeto…" />
        <Label fx:id="statusLabel" text="Nenhum projeto aberto." wrapText="true" />
        <Label fx:id="xmlRootLabel" wrapText="true" />
      </VBox>
    </SplitPane>
  </center>
</BorderPane>
